# ============================================
# FRONTEND ENV — Threads Clone (Next.js :3000)
# Copy file này thành .env.local rồi điền giá trị thật
# Lưu ý: biến phải có tiền tố NEXT_PUBLIC_ mới dùng được ở client
# ============================================

# URL gốc của API backend (bao gồm prefix /api/v1)
NEXT_PUBLIC_API_URL="http://localhost:5000/api/v1"

# URL của Socket.io server (không kèm /api/v1) — dùng cho thông báo & chat realtime
NEXT_PUBLIC_SOCKET_URL="http://localhost:5000"

# Google OAuth Client ID — lấy từ Google Cloud Console (giống GOOGLE_CLIENT_ID của backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
