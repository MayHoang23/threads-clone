generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// USER
// ========================
enum Role {
  USER
  ADMIN
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String   @unique
  password    String
  displayName String?
  avatar      String?
  coverImage  String?
  bio         String?
  isPrivate   Boolean  @default(false)
  isVerified  Boolean  @default(false)
  isBanned    Boolean  @default(false)
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Xác thực email + reset mật khẩu
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?

  // Quan hệ
  posts         Post[]
  likes         Like[]
  comments      Comment[]
  commentLikes  CommentLike[]
  followers     Follow[]       @relation("following")
  following     Follow[]       @relation("follower")
  sentRequests  Friendship[]   @relation("requester")
  receivedRequests Friendship[] @relation("receiver")
  sentMessages  Message[]
  notifications Notification[] @relation("receiver")
  triggered     Notification[] @relation("triggered")
  reports       Report[]
  savedPosts    SavedPost[]
  conversations ConversationMember[]
  settings      UserSettings?
  stories       Story[]
  storyViews    StoryView[]
}

// ========================
// USER SETTINGS
// ========================
model UserSettings {
  id               String       @id @default(cuid())
  userId           String       @unique
  likeNotif        Boolean      @default(true)
  commentNotif     Boolean      @default(true)
  followNotif      Boolean      @default(true)
  emailNotif       Boolean      @default(false)
  allowMessagesFrom MessagesFrom @default(EVERYONE)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ========================
// POST
// ========================
model Post {
  id        String      @id @default(cuid())
  content   String?
  privacy   Privacy     @default(PUBLIC)
  isHidden  Boolean     @default(false) // Admin ẩn bài khi xử lý vi phạm (thay vì xóa)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Link preview (Open Graph) khi paste URL vào bài
  linkUrl         String?
  linkTitle       String?
  linkDescription String?
  linkImage       String?
  linkSiteName    String?

  // Khoá ngoại
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Repost & Quote (self-relation) — onDelete SetNull để không xoá lan khi bài gốc bị xoá
  repostOfId   String?
  repostOf     Post?  @relation("Reposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts      Post[] @relation("Reposts")
  quotedPostId String?
  quotedPost   Post?  @relation("Quotes", fields: [quotedPostId], references: [id], onDelete: SetNull)
  quotes       Post[] @relation("Quotes")

  // Quan hệ
  media         Media[]
  likes         Like[]
  comments      Comment[]
  hashtags      PostHashtag[]
  savedBy       SavedPost[]
  reports       Report[]
  notifications Notification[]
}

// ========================
// MEDIA (ảnh/video của bài viết)
// ========================
model Media {
  id        String    @id @default(cuid())
  url       String
  type      MediaType
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ========================
// LIKE
// ========================
model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId]) // 1 user chỉ like 1 bài 1 lần
}

// ========================
// COMMENT
// ========================
model Comment {
  id        String    @id @default(cuid())
  content   String
  mediaUrl  String?   // URL ảnh đính kèm (tuỳ chọn)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId    String
  postId    String
  parentId  String?   // null = comment gốc, có giá trị = reply

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  // onDelete Cascade: xoá comment gốc → tự xoá các reply con
  parent    Comment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("replies")
  likes     CommentLike[]
}

// ========================
// COMMENT LIKE (thích bình luận)
// ========================
model CommentLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  commentId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId]) // 1 user chỉ thích 1 comment 1 lần
}

// ========================
// FOLLOW
// ========================
model Follow {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  followerId  String
  followingId String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// ========================
// FRIENDSHIP (kết bạn)
// ========================
model Friendship {
  id          String           @id @default(cuid())
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  requesterId String
  receiverId  String
  requester   User             @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver    User             @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

// ========================
// SAVED POST
// ========================
model SavedPost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

// ========================
// HASHTAG
// ========================
model Hashtag {
  id        String        @id @default(cuid())
  name      String        @unique
  posts     PostHashtag[]
}

model PostHashtag {
  postId    String
  hashtagId String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
}

// ========================
// MESSAGE & CONVERSATION
// ========================
model Conversation {
  id            String               @id @default(cuid())
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  lastMessageAt DateTime?            // Thời gian tin nhắn mới nhất — dùng để sort
  members       ConversationMember[]
  messages      Message[]
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  mediaUrl       String?      // URL ảnh/video/âm thanh đính kèm (tuỳ chọn)
  mediaType      String?      // "image" | "video" | "audio" — loại media đính kèm
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  senderId       String
  conversationId String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ========================
// NOTIFICATION
// ========================
model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  receiverId  String
  // Nullable: notification hệ thống (vd POST_HIDDEN do admin ẩn bài) không có user kích hoạt
  triggeredId String?
  postId      String?
  receiver    User             @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  triggered   User?            @relation("triggered", fields: [triggeredId], references: [id], onDelete: Cascade)
  post        Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ========================
// REPORT
// ========================
model Report {
  id        String       @id @default(cuid())
  reason    String
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  userId    String
  postId    String?
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ========================
// ENUMS
// ========================
enum Privacy {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum MediaType {
  IMAGE
  VIDEO
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  LIKE
  COMMENT
  COMMENT_LIKE
  MENTION
  FOLLOW
  FRIEND_REQUEST
  MESSAGE
  POST_HIDDEN
  REPOST
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum MessagesFrom {
  EVERYONE
  FOLLOWING
  NONE
}

// ========================
// STORY (Tin 24h)
// ========================
model Story {
  id        String      @id @default(cuid())
  userId    String
  mediaUrl  String?
  mediaType String?     // "image" | "video" | "text"
  caption   String?
  bgColor   String?     // Màu nền cho story văn bản
  expiresAt DateTime
  createdAt DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  views     StoryView[]
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  userId   String
  viewedAt DateTime @default(now())

  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
}
