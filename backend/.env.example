# ============================================
# BACKEND ENV — Threads Clone (Express :5000)
# Copy file này thành .env rồi điền giá trị thật
# ============================================

# --- Database (PostgreSQL + Prisma) ---
# Chuỗi kết nối Postgres: postgresql://user:password@host:port/tên_db
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/threads_db?schema=public"

# --- Server ---
# Cổng chạy backend Express (mặc định 5000 nếu để trống)
PORT=5000

# URL của frontend — dùng cho CORS và tạo link trong email xác thực/reset mật khẩu
FRONTEND_URL="http://localhost:3000"

# --- JWT (xác thực) ---
# Khóa bí mật ký access token (hết hạn 15 phút) — đặt chuỗi ngẫu nhiên dài
JWT_SECRET="your_jwt_access_secret_random_string"
# Khóa bí mật ký refresh token (hết hạn 7 ngày) — đồng thời dùng để xác thực Socket.io
JWT_REFRESH_SECRET="your_jwt_refresh_secret_random_string"

# --- Cloudinary (lưu trữ ảnh/video) ---
# Lấy từ Dashboard Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# --- AI ---
# Google Gemini API key (model gemini-2.5-flash) — dùng cho caption, hashtag, kiểm duyệt nội dung
GEMINI_API_KEY="your_gemini_api_key"
# Anthropic API key — tùy chọn, hiện CHƯA dùng (giữ lại cho client cấu hình sẵn, có thể để trống)
ANTHROPIC_API_KEY=""

# --- Email (Nodemailer qua Gmail) ---
# Email Gmail dùng để gửi mail xác thực / quên mật khẩu
GMAIL_USER="your_email@gmail.com"
# App Password 16 ký tự của Gmail (KHÔNG phải mật khẩu đăng nhập thường)
GMAIL_PASS="your_gmail_app_password"

# --- Cờ tiện ích khi dev/demo ---
# Đặt "true" để bỏ qua bước xác thực email khi đăng ký/đăng nhập (tiện demo khi chưa cấu hình SMTP)
SKIP_EMAIL_VERIFY=false
